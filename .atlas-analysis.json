  "keyFeatures": [
    "Schedule Docker Compose-style workloads across multiple nodes without Kubernetes",
    "Central control plane (cara-server) with distributed per-node agents (cara-agent)",
    "Declarative YAML manifests for Nodes and Projects",
    "CLI tool (caractrl) for managing nodes, projects, and port forwarding",
    "Automatic project lifecycle management: Pending → Scheduled → Running → Failed",
    "Shared Docker bridge network for inter-service discovery within a project",
    "WebSocket-based port forwarding to containers on remote nodes",
    "Named volume support for persistent and ephemeral storage",
    "HTTP ingress rules with internal scope support"
  ],
  "publicApiSurface": [
    "POST /api/v1/nodes — Register a node",
    "GET /api/v1/nodes — List all nodes",
    "GET /api/v1/nodes/{name} — Get a single node",
    "DELETE /api/v1/nodes/{name} — Delete a node",
    "POST /api/v1/nodes/{name}/heartbeat — Send a heartbeat",
    "POST /api/v1/projects — Create a project",
    "GET /api/v1/projects — List projects (?phase=, ?nodeRef=)",
    "GET /api/v1/projects/{name} — Get a single project",
    "DELETE /api/v1/projects/{name} — Delete a project",
    "PATCH /api/v1/projects/{name}/status — Update project status",
    "caractrl apply -f <manifest> — Apply a resource manifest",
    "caractrl get nodes [name] — List or get nodes",
    "caractrl get projects [name] [--phase] — List or get projects",
    "caractrl delete node|project <name> — Delete a resource",
    "caractrl port-forward <project>/<service> [LOCAL:]REMOTE — Forward ports to containers"
  ]
}
